# Database
DATABASE_URL=postgresql+asyncpg://hoteluser:hotelpass@postgres:5432/hoteldb
DATABASE_URL_SYNC=postgresql://hoteluser:hotelpass@postgres:5432/hoteldb

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Payments — Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Payments — ONVO (Costa Rica)
# ONVO_SECRET_KEY: onvo_test_secret_key_... / onvo_live_secret_key_... (server-side only)
# ONVO_API_KEY: publishable key (onvo_test_publishable_key_...)
# ONVO_WEBHOOK_SECRET: generated by ONVO when registering the webhook endpoint
ONVO_SECRET_KEY=
ONVO_API_KEY=
ONVO_WEBHOOK_SECRET=
ONVO_BASE_URL=https://api.onvopay.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME=Hotel Reservas
EMAILS_FROM_EMAIL=reservas@hotel.com

# Exchange Rate API
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_BASE_CURRENCY=USD

# Environment
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Booking — 15 minutos (900s) de candado Redis por habitación/fechas
BOOKING_LOCK_TTL_SECONDS=900
# Rate limiting disponibilidad: peticiones por minuto por IP
AVAILABILITY_RATE_LIMIT=60/minute
